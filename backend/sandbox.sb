(version 1)
(allow default)
(deny file-write*)
(allow file-write* 
    (subpath "/private/var/folders")
    (subpath "/Users/justin/python-ai-academy/.pytest_cache")
    (subpath "/Users/justin/python-ai-academy/backend/__pycache__")
    (subpath "/Users/justin/python-ai-academy/__pycache__")
    (literal "/Users/justin/python-ai-academy/active_lab.py")
    (literal "/Users/justin/python-ai-academy/test_active_lab.py")
    (literal "/Users/justin/python-ai-academy/backend/sandbox.sb")
    (literal "/dev/null")
    (literal "/dev/dtracehelper")
    (literal "/dev/stdout")
    (literal "/dev/stderr")
    (literal "/dev/tty")
)
(deny network-outbound)
(allow network-outbound (local ip "localhost:*"))
(allow network-outbound (literal "/private/var/run/mDNSResponder"))
