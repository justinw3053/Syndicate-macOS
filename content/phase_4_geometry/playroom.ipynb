    "\n",
    "sim_a = cosine_similarity(q, doc_a)\n",
    "sim_b = cosine_similarity(q, doc_b)\n",
    "\n",
    "print(f\"Cosine Similarity to Doc A: {sim_a:.4f}\")\n",
    "print(f\"Cosine Similarity to Doc B: {sim_b:.4f}\")\n",
    "\n",
    "assert abs(sim_a - 1.0) < 1e-6, \"Doc A must have a similarity of 1.0 (perfect directional alignment)\"\n",
    "assert abs(sim_b - 0.707106) < 1e-4, \"Doc B must have a similarity of roughly 0.707\"\n",
    "print(\"Success! Cosine Similarity metric verified.\")"
