    "    [\"p\", \"u\", \"g\", \"</w>\"],\n",
    "    [\"h\", \"u\", \"g\", \"s\", \"</w>\"],\n",
    "    [\"h\", \"u\", \"g\", \"</w>\"],\n",
    "    [\"p\", \"u\", \"g\", \"</w>\"]\n",
    "]\n",
    "\n",
    "# TODO: Write a function to count frequencies of adjacent pairs of tokens in the corpus.\n",
    "def get_stats(corpus: List[List[str]]) -> Dict[Tuple[str, str], int]:\n",
